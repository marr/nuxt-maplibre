{
  "name": "@dmarr/nuxt-maplibre",
  "version": "2.1.0",
  "description": "A Nuxt module to use MapLibre",
  "homepage": "https://marr.github.io/nuxt-maplibre",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marr/nuxt-maplibre.git"
  },
  "bugs": {
    "url": "https://github.com/marr/nuxt-maplibre/issues"
  },
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs",
      "require": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "types": "./dist/types.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "demo:generate": "nuxi generate playground",
    "dev": "nuxi dev playground",
    "dev:host": "nuxi dev playground --host",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxi prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@indoorequal/vue-maplibre-gl": "^8.4.2",
    "lucide-vue-next": "^1.0.0",
    "maplibre-gl": "^5.21.1",
    "maplibre-google-maps": "^1.1.0",
    "maplibre-theme": "^1.0.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.101",
    "@nuxt/devtools": "latest",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxt/ui": "^4.6.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "caniuse-lite": "^1.0.30001782",
    "changelogen": "^0.6.2",
    "eslint": "^10.1.0",
    "nuxt": "^4.4.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "tailwindcss": "^4.2.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.33.0",
  "peerDependencies": {
    "nuxt": ">=3.0.0"
  }
}
